{
  "dashboard": {
    "id": null,
    "uid": "mdm-platform-overview",
    "title": "MDM Platform Overview",
    "tags": ["mdm", "overview"],
    "timezone": "browser",
    "refresh": "30s",
    "time": { "from": "now-1h", "to": "now" },
    "templating": {
      "list": [
        {
          "name": "org",
          "type": "query",
          "query": "label_values(mdm_devices_total, org)",
          "datasource": "Prometheus",
          "includeAll": true,
          "allValue": ".*",
          "current": { "text": "All", "value": "$__all" }
        },
        {
          "name": "timeRange",
          "type": "interval",
          "options": [
            { "text": "5m", "value": "5m" },
            { "text": "15m", "value": "15m" },
            { "text": "1h", "value": "1h" },
            { "text": "6h", "value": "6h" },
            { "text": "24h", "value": "24h" }
          ],
          "current": { "text": "5m", "value": "5m" }
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "Request Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(mdm_api_request_duration_seconds_count{org=~\"$org\"}[$timeRange]))",
            "legendFormat": "Total Requests/s"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "reqps" }
        }
      },
      {
        "id": 2,
        "title": "Error Rate (4xx/5xx)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(mdm_api_request_duration_seconds_count{status=~\"4..\",org=~\"$org\"}[$timeRange])) / sum(rate(mdm_api_request_duration_seconds_count{org=~\"$org\"}[$timeRange])) * 100",
            "legendFormat": "4xx %"
          },
          {
            "expr": "sum(rate(mdm_api_request_duration_seconds_count{status=~\"5..\",org=~\"$org\"}[$timeRange])) / sum(rate(mdm_api_request_duration_seconds_count{org=~\"$org\"}[$timeRange])) * 100",
            "legendFormat": "5xx %"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "percent" }
        }
      },
      {
        "id": 3,
        "title": "API Latency (p50 / p95 / p99)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(mdm_api_request_duration_seconds_bucket{org=~\"$org\"}[$timeRange])) by (le))",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(mdm_api_request_duration_seconds_bucket{org=~\"$org\"}[$timeRange])) by (le))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(mdm_api_request_duration_seconds_bucket{org=~\"$org\"}[$timeRange])) by (le))",
            "legendFormat": "p99"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "s" }
        }
      },
      {
        "id": 4,
        "title": "Active Services",
        "type": "stat",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "count(up{job=~\"mdm-.*\"} == 1)",
            "legendFormat": "Healthy"
          },
          {
            "expr": "count(up{job=~\"mdm-.*\"} == 0)",
            "legendFormat": "Down"
          }
        ]
      }
    ]
  }
}
